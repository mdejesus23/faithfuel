---
import MainLayout from '../layouts/MainLayout.astro';

const contactMethods = [
  {
    title: 'Email',
    value: 'hello@faithfuel.com',
    href: 'mailto:hello@faithfuel.com',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>`,
  },
  {
    title: 'Instagram',
    value: '@faithfuelco',
    href: '#',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>`,
  },
];
---

<MainLayout
  title="Contact"
  description="Get in touch with the FaithFuel team. We'd love to hear from you."
>
  <!-- Hero -->
  <section class="bg-surface py-16 border-b border-gray-100">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <p class="text-accent text-sm font-semibold uppercase tracking-widest mb-3">Get In Touch</p>
      <h1 class="text-4xl sm:text-5xl font-black">We'd love to hear from you.</h1>
      <p class="mt-4 text-gray-500 text-lg max-w-md mx-auto">
        Questions, custom orders, wholesale inquiries — drop us a message and we'll get back to
        you within 24 hours.
      </p>
    </div>
  </section>

  <!-- Content -->
  <section class="py-20 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 grid md:grid-cols-2 gap-16 items-start">
      <!-- Contact Methods -->
      <div>
        <h2 class="text-2xl font-black mb-8">Reach out directly</h2>
        <div class="space-y-5">
          {
            contactMethods.map((m) => (
              <a
                href={m.href}
                class="flex items-center gap-4 p-5 rounded-2xl border border-gray-100 hover:border-accent hover:shadow-sm transition-all group"
              >
                <div class="w-11 h-11 bg-accent/10 text-accent rounded-xl flex items-center justify-center group-hover:bg-accent group-hover:text-white transition-colors" set:html={m.icon} />
                <div>
                  <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider">{m.title}</p>
                  <p class="font-bold text-primary mt-0.5">{m.value}</p>
                </div>
              </a>
            ))
          }
        </div>

        <div class="mt-10 p-6 bg-primary rounded-2xl text-white">
          <h3 class="font-bold mb-2">Order Support</h3>
          <p class="text-gray-400 text-sm leading-relaxed">
            For questions about an existing order, please include your name and order reference
            in your message and we'll prioritise your enquiry.
          </p>
        </div>
      </div>

      <!-- Form -->
      <div>
        <h2 class="text-2xl font-black mb-8">Send a message</h2>
        <form
          method="POST"
          action="#"
          class="space-y-4"
        >
          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1.5" for="cf-name">
                Name
              </label>
              <input
                id="cf-name"
                type="text"
                name="name"
                required
                placeholder="John Doe"
                class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent"
              />
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1.5" for="cf-email">
                Email
              </label>
              <input
                id="cf-email"
                type="email"
                name="email"
                required
                placeholder="you@example.com"
                class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent"
              />
            </div>
          </div>

          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1.5" for="cf-subject">
              Subject
            </label>
            <input
              id="cf-subject"
              type="text"
              name="subject"
              placeholder="Order question, wholesale, etc."
              class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent"
            />
          </div>

          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1.5" for="cf-message">
              Message
            </label>
            <textarea
              id="cf-message"
              name="message"
              rows={5}
              required
              placeholder="How can we help you?"
              class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent resize-none"
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full bg-primary text-white font-bold py-3.5 rounded-xl hover:bg-accent transition-colors"
          >
            Send Message
          </button>
        </form>
      </div>
    </div>
  </section>
</MainLayout>
