---
import MainLayout from '../layouts/MainLayout.astro';
const canonical = Astro.url.href;
const contactMethods = [
  {
    title: 'Email',
    value: 'faithfuel@melnerdz.com',
    href: 'mailto:faithfuel@melnerdz.com',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>`,
  },
  {
    title: 'Phone',
    value: '+63 977 639 3459',
    href: 'tel:+639776393459',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>`,
  },
  {
    title: 'Facebook',
    value: 'facebook.com/faithfuelco',
    href: 'https://facebook.com/faithfuelco',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>`,
  },
];
---

<MainLayout
  title="Contact"
  description="Get in touch with the FaithFuel team. We'd love to hear from you."
  structuredData={{
    '@context': 'https://schema.org',
    '@type': 'ContactPage',
    name: 'Contact',
    description:
      "Get in touch with the FaithFuel team. We'd love to hear from you.",
    url: canonical,
  }}
>
  <!-- Hero -->
  <section class="bg-surface border-b border-gray-100 py-16">
    <div class="mx-auto max-w-4xl px-4 text-center sm:px-6">
      <p
        class="text-accent mb-3 text-sm font-semibold tracking-widest uppercase"
      >
        Get In Touch
      </p>
      <h1 class="text-4xl font-black sm:text-5xl">
        We'd love to hear from you.
      </h1>
      <p class="mx-auto mt-4 max-w-md text-lg text-gray-500">
        Questions, custom orders, wholesale inquiries — drop us a message and
        we'll get back to you within 24 hours.
      </p>
    </div>
  </section>

  <!-- Content -->
  <section class="bg-white py-20">
    <div class="mx-auto max-w-2xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-8 text-center text-2xl font-black">Reach out directly</h2>
      <div class="space-y-5">
        {
          contactMethods.map((m) => (
            <a
              href={m.href}
              class="hover:border-accent group flex items-center gap-4 rounded-2xl border border-gray-100 p-5 transition-all hover:shadow-sm"
            >
              <div
                class="bg-accent/10 text-accent group-hover:bg-accent flex h-11 w-11 shrink-0 items-center justify-center rounded-xl transition-colors group-hover:text-white"
                set:html={m.icon}
              />
              <div>
                <p class="text-xs font-semibold tracking-wider text-gray-400 uppercase">
                  {m.title}
                </p>
                <p class="text-primary mt-0.5 font-bold">{m.value}</p>
              </div>
            </a>
          ))
        }
      </div>

      <div class="bg-primary mt-10 rounded-2xl p-6 text-white">
        <h3 class="mb-2 font-bold">Order Support</h3>
        <p class="text-sm leading-relaxed text-gray-400">
          For questions about an existing order, please include your name and
          order reference in your message and we'll prioritise your enquiry.
        </p>
      </div>
    </div>
  </section>
</MainLayout>
