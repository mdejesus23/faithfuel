---
import MainLayout from '../layouts/MainLayout.astro';
const canonical = Astro.url.href;
const contactMethods = [
  {
    title: 'Email',
    value: 'hello@faithfuel.com',
    href: 'mailto:hello@faithfuel.com',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>`,
  },
  {
    title: 'Instagram',
    value: '@faithfuelco',
    href: '#',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>`,
  },
];
---

<MainLayout
  title="Contact"
  description="Get in touch with the FaithFuel team. We'd love to hear from you."
  structuredData={{
    '@context': 'https://schema.org',
    '@type': 'ContactPage',
    name: 'Contact',
    description:
      "Get in touch with the FaithFuel team. We'd love to hear from you.",
    url: canonical,
  }}
>
  <!-- Hero -->
  <section class="bg-surface border-b border-gray-100 py-16">
    <div class="mx-auto max-w-4xl px-4 text-center sm:px-6">
      <p
        class="text-accent mb-3 text-sm font-semibold tracking-widest uppercase"
      >
        Get In Touch
      </p>
      <h1 class="text-4xl font-black sm:text-5xl">
        We'd love to hear from you.
      </h1>
      <p class="mx-auto mt-4 max-w-md text-lg text-gray-500">
        Questions, custom orders, wholesale inquiries — drop us a message and
        we'll get back to you within 24 hours.
      </p>
    </div>
  </section>

  <!-- Content -->
  <section class="bg-white py-20">
    <div
      class="mx-auto grid max-w-5xl items-start gap-16 px-4 sm:px-6 md:grid-cols-2 lg:px-8"
    >
      <!-- Contact Methods -->
      <div>
        <h2 class="mb-8 text-2xl font-black">Reach out directly</h2>
        <div class="space-y-5">
          {
            contactMethods.map((m) => (
              <a
                href={m.href}
                class="hover:border-accent group flex items-center gap-4 rounded-2xl border border-gray-100 p-5 transition-all hover:shadow-sm"
              >
                <div
                  class="bg-accent/10 text-accent group-hover:bg-accent flex h-11 w-11 items-center justify-center rounded-xl transition-colors group-hover:text-white"
                  set:html={m.icon}
                />
                <div>
                  <p class="text-xs font-semibold tracking-wider text-gray-400 uppercase">
                    {m.title}
                  </p>
                  <p class="text-primary mt-0.5 font-bold">{m.value}</p>
                </div>
              </a>
            ))
          }
        </div>

        <div class="bg-primary mt-10 rounded-2xl p-6 text-white">
          <h3 class="mb-2 font-bold">Order Support</h3>
          <p class="text-sm leading-relaxed text-gray-400">
            For questions about an existing order, please include your name and
            order reference in your message and we'll prioritise your enquiry.
          </p>
        </div>
      </div>

      <!-- Form -->
      <div>
        <h2 class="mb-8 text-2xl font-black">Send a message</h2>
        <form method="POST" action="#" class="space-y-4">
          <div class="grid gap-4 sm:grid-cols-2">
            <div>
              <label
                class="mb-1.5 block text-sm font-semibold text-gray-700"
                for="cf-name"
              >
                Name
              </label>
              <input
                id="cf-name"
                type="text"
                name="name"
                required
                placeholder="John Doe"
                class="focus:ring-primary w-full rounded-xl border border-gray-200 px-4 py-3 text-sm focus:border-transparent focus:ring-2 focus:outline-none"
              />
            </div>
            <div>
              <label
                class="mb-1.5 block text-sm font-semibold text-gray-700"
                for="cf-email"
              >
                Email
              </label>
              <input
                id="cf-email"
                type="email"
                name="email"
                required
                placeholder="you@example.com"
                class="focus:ring-primary w-full rounded-xl border border-gray-200 px-4 py-3 text-sm focus:border-transparent focus:ring-2 focus:outline-none"
              />
            </div>
          </div>

          <div>
            <label
              class="mb-1.5 block text-sm font-semibold text-gray-700"
              for="cf-subject"
            >
              Subject
            </label>
            <input
              id="cf-subject"
              type="text"
              name="subject"
              placeholder="Order question, wholesale, etc."
              class="focus:ring-primary w-full rounded-xl border border-gray-200 px-4 py-3 text-sm focus:border-transparent focus:ring-2 focus:outline-none"
            />
          </div>

          <div>
            <label
              class="mb-1.5 block text-sm font-semibold text-gray-700"
              for="cf-message"
            >
              Message
            </label>
            <textarea
              id="cf-message"
              name="message"
              rows={5}
              required
              placeholder="How can we help you?"
              class="focus:ring-primary w-full resize-none rounded-xl border border-gray-200 px-4 py-3 text-sm focus:border-transparent focus:ring-2 focus:outline-none"
            ></textarea>
          </div>

          <button
            type="submit"
            class="bg-primary hover:bg-accent w-full rounded-xl py-3.5 font-bold text-white transition-colors"
          >
            Send Message
          </button>
        </form>
      </div>
    </div>
  </section>
</MainLayout>
