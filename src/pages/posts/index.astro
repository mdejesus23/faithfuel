---
import MainLayout from '../../layouts/MainLayout.astro';
import PostCard from '../../components/PostCard.astro';
import Pagination from '../../components/Pagination.astro';
import { getCollection } from 'astro:content';

const canonical = Astro.url.href;
const allPosts = (await getCollection('posts')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

const allTags = ['all', ...new Set(allPosts.flatMap((p) => p.data.tags ?? []))];
---

<MainLayout
  title="Blog"
  description="Faith reflections, devotionals, and inspiration from the FaithFuel community."
  structuredData={{
    '@context': 'https://schema.org',
    '@type': 'Blog',
    '@id': canonical,
    name: 'FaithFuel Blog',
    description:
      'Faith reflections, devotionals, and inspiration from the FaithFuel community.',
    url: canonical,
  }}
>
  <!-- Hero -->
  <section class="bg-surface border-b border-gray-100 py-14">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <p class="text-accent mb-2 text-sm font-semibold tracking-widest uppercase">
        Blog
      </p>
      <h1 class="text-4xl font-black sm:text-5xl">Faith & Reflection</h1>
      <p class="mt-3 max-w-md text-gray-500">
        {allPosts.length} {allPosts.length === 1 ? 'article' : 'articles'} on faith, devotion, and the journey.
      </p>
    </div>
  </section>

  <!-- Filters + Grid -->
  <section class="bg-white py-12">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <!-- Search -->
      <div class="mb-6 relative max-w-md">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-gray-400 pointer-events-none"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z" />
        </svg>
        <input
          id="search-input"
          type="search"
          placeholder="Search articles…"
          class="w-full rounded-xl border border-gray-200 pl-9 pr-4 py-2.5 text-sm font-medium text-gray-700 placeholder-gray-400 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 transition-colors"
        />
      </div>

      <!-- Tag filter -->
      {
        allTags.length > 1 && (
          <div class="mb-10 flex flex-wrap gap-2" id="filter-bar">
            {allTags.map((tag) => (
              <button
                data-filter={tag}
                class={`filter-btn rounded-full border px-4 py-2 text-sm font-semibold capitalize transition-all ${
                  tag === 'all'
                    ? 'bg-primary border-primary text-white'
                    : 'border-gray-200 text-gray-600 hover:border-gray-400'
                }`}
              >
                {tag}
              </button>
            ))}
          </div>
        )
      }

      <!-- Grid -->
      <div
        class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3"
        id="post-grid"
      >
        {
          allPosts.map((post) => (
            <div
              data-tags={JSON.stringify(post.data.tags ?? [])}
              data-title={post.data.title.toLowerCase()}
              data-excerpt={post.data.excerpt.toLowerCase()}
              class="post-item"
            >
              <PostCard
                id={post.id}
                title={post.data.title}
                excerpt={post.data.excerpt}
                author={post.data.author}
                date={post.data.date}
                image={post.data.image}
                tags={post.data.tags}
              />
            </div>
          ))
        }
      </div>

      <!-- Empty state -->
      <div id="empty-state" class="hidden py-20 text-center text-gray-400">
        <p class="text-lg font-semibold">No articles found.</p>
      </div>

      <Pagination gridId="post-grid" />
    </div>
  </section>
</MainLayout>

<script>
  const ITEMS_PER_PAGE = 9;

  let currentPage = 1;
  let currentFilter = 'all';
  let currentSearch = '';

  const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const items = document.querySelectorAll<HTMLElement>('.post-item');
  const emptyState = document.getElementById('empty-state');
  const pageInfo = document.getElementById('page-info');
  const prevBtn = document.getElementById('prev-page') as HTMLButtonElement | null;
  const nextBtn = document.getElementById('next-page') as HTMLButtonElement | null;
  const pagination = document.getElementById('pagination');
  const searchInput = document.getElementById('search-input') as HTMLInputElement | null;
  const gridId = pagination?.dataset.gridId ?? 'post-grid';

  function getFilteredItems(): HTMLElement[] {
    return Array.from(items).filter((item) => {
      const tags: string[] = JSON.parse(item.dataset.tags ?? '[]');
      const matchesTag = currentFilter === 'all' || tags.includes(currentFilter);
      const q = currentSearch.trim();
      const matchesSearch =
        q === '' ||
        (item.dataset.title ?? '').includes(q) ||
        (item.dataset.excerpt ?? '').includes(q);
      return matchesTag && matchesSearch;
    });
  }

  function renderPage() {
    const filtered = getFilteredItems();
    const totalPages = Math.max(1, Math.ceil(filtered.length / ITEMS_PER_PAGE));
    currentPage = Math.min(currentPage, totalPages);

    const start = (currentPage - 1) * ITEMS_PER_PAGE;
    const end = start + ITEMS_PER_PAGE;

    items.forEach((item) => (item.style.display = 'none'));
    filtered.slice(start, end).forEach((item) => (item.style.display = ''));

    emptyState?.classList.toggle('hidden', filtered.length > 0);
    pagination?.classList.toggle('hidden', totalPages <= 1);

    if (pageInfo) pageInfo.textContent = `Page ${currentPage} of ${totalPages}`;
    if (prevBtn) prevBtn.disabled = currentPage <= 1;
    if (nextBtn) nextBtn.disabled = currentPage >= totalPages;
  }

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      currentFilter = btn.dataset.filter ?? 'all';
      currentPage = 1;

      buttons.forEach((b) => {
        b.classList.remove('bg-primary', 'text-white', 'border-primary');
        b.classList.add('border-gray-200', 'text-gray-600');
      });
      btn.classList.add('bg-primary', 'text-white', 'border-primary');
      btn.classList.remove('border-gray-200', 'text-gray-600');

      renderPage();
    });
  });

  prevBtn?.addEventListener('click', () => {
    if (currentPage > 1) {
      currentPage--;
      renderPage();
      document.getElementById(gridId)?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  });

  nextBtn?.addEventListener('click', () => {
    const totalPages = Math.ceil(getFilteredItems().length / ITEMS_PER_PAGE);
    if (currentPage < totalPages) {
      currentPage++;
      renderPage();
      document.getElementById(gridId)?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  });

  searchInput?.addEventListener('input', () => {
    currentSearch = searchInput.value.toLowerCase();
    currentPage = 1;
    renderPage();
  });

  renderPage();
</script>
