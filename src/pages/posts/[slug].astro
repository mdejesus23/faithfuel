---
import { Image } from 'astro:assets';
import MainLayout from '../../layouts/MainLayout.astro';
import Prose from '../../components/Prose.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { title, author, date, excerpt, image, tags, articleSection, keywords } = post.data;
const { Content } = await render(post);

const ogImage = `/og/posts/${post.id}.png`;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const canonical = Astro.url.href;

const allPosts = await getCollection('posts');
const related = allPosts
  .filter(
    (p) =>
      p.id !== post.id &&
      (p.data.tags ?? []).some((t) => (tags ?? []).includes(t)),
  )
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<MainLayout
  title={title}
  description={excerpt}
  image={ogImage}
  structuredData={{
    '@context': 'https://schema.org',
    '@type': 'BlogPosting',
    headline: title,
    description: excerpt,
    author: { '@type': 'Person', name: author },
    datePublished: date.toISOString(),
    articleSection: articleSection,
    keywords: keywords?.join(', '),
    url: canonical,
  }}
>
  <!-- Breadcrumb -->
  <div class="bg-surface border-b border-gray-100">
    <div class="mx-auto max-w-7xl px-4 py-3 sm:px-6 lg:px-8">
      <nav class="flex items-center gap-2 text-xs text-gray-400">
        <a href="/" class="hover:text-accent transition-colors">Home</a>
        <span>/</span>
        <a href="/posts" class="hover:text-accent transition-colors">Blog</a>
        <span>/</span>
        <span class="text-primary font-medium">{title}</span>
      </nav>
    </div>
  </div>

  <!-- Hero Image -->
  <div class="bg-surface">
    <div class="mx-auto max-w-4xl px-4 pt-10 sm:px-6 lg:px-8">
      <div class="overflow-hidden rounded-2xl aspect-video">
        <Image
          src={image}
          alt={title}
          loading="eager"
          class="h-full w-full object-cover"
        />
      </div>
    </div>
  </div>

  <!-- Article -->
  <article class="bg-surface pb-20 pt-10">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <!-- Meta -->
      <header class="mb-10">
        {
          tags && tags.length > 0 && (
            <div class="mb-4 flex flex-wrap gap-2">
              {tags.map((tag) => (
                <span class="bg-accent/10 text-accent rounded-full px-3 py-1 text-xs font-semibold capitalize">
                  {tag}
                </span>
              ))}
            </div>
          )
        }
        <h1 class="text-3xl font-black leading-tight sm:text-4xl lg:text-5xl">
          {title}
        </h1>
        <p class="mt-4 text-sm text-gray-400">
          By <span class="text-primary font-semibold">{author}</span> · {formattedDate}
        </p>
        <p class="mt-4 text-lg leading-relaxed text-gray-500">{excerpt}</p>
        <hr class="mt-8 border-gray-100" />
      </header>

      <!-- Body -->
      <Prose>
        <Content />
      </Prose>

      <!-- Footer tags -->
      {
        tags && tags.length > 0 && (
          <footer class="mt-12 border-t border-gray-100 pt-6">
            <p class="mb-3 text-xs font-semibold tracking-widest text-gray-400 uppercase">
              Tagged
            </p>
            <div class="flex flex-wrap gap-2">
              {tags.map((tag) => (
                <span class="bg-surface rounded-full border border-gray-100 px-3 py-1 text-xs text-gray-500 capitalize">
                  #{tag}
                </span>
              ))}
            </div>
          </footer>
        )
      }
    </div>
  </article>

  <!-- Related Posts -->
  {
    related.length > 0 && (
      <section class="bg-white py-16">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
          <h2 class="mb-8 text-2xl font-black">You might also like</h2>
          <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {related.map((p) => (
              <a
                href={`/posts/${p.id}`}
                class="group block overflow-hidden rounded-2xl border border-gray-100 bg-white transition-all hover:shadow-md"
              >
                <div class="aspect-video overflow-hidden bg-gray-50">
                  <Image
                    src={p.data.image}
                    alt={p.data.title}
                    loading="lazy"
                    class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                  />
                </div>
                <div class="p-4">
                  <p class="text-sm font-bold leading-snug">{p.data.title}</p>
                  <p class="mt-1 line-clamp-2 text-xs text-gray-400">{p.data.excerpt}</p>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )
  }
</MainLayout>
