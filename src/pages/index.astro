---
import MainLayout from '../layouts/MainLayout.astro';
import ProductCard from '../components/ProductCard.astro';
import { getCollection } from 'astro:content';

const allProducts = await getCollection('products');
const featured = allProducts.filter((p) => p.data.featured).slice(0, 3);
---

<MainLayout
  title="Wear Your Faith"
  description="Catholic apparel rooted in tradition — t-shirts inspired by the saints, the Gospel, and the beauty of the faith."
>
  <!-- Hero -->
  <section class="relative min-h-[90vh] flex items-center bg-primary overflow-hidden">
    <!-- Decorative background text -->
    <span
      class="absolute inset-0 flex items-center justify-center text-[20vw] font-black text-white/3 select-none pointer-events-none leading-none"
      aria-hidden="true"
    >
      FAITH
    </span>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 text-white">
      <p class="text-accent text-sm font-semibold uppercase tracking-widest mb-4">
        Rooted in Tradition — 2026
      </p>
      <h1 class="text-5xl sm:text-6xl lg:text-7xl font-black leading-[1.05] max-w-2xl">
        Clothed in<br /><span class="text-accent">His Grace.</span>
      </h1>
      <p class="mt-6 text-gray-400 text-lg leading-relaxed max-w-xl">
        Faith-inspired apparel for Catholics who carry the cross daily — bold enough to witness,
        humble enough to serve.
      </p>
      <div class="mt-10 flex flex-wrap gap-4">
        <a
          href="/products"
          class="inline-flex items-center gap-2 bg-accent text-white font-bold px-8 py-4 rounded-xl hover:bg-accent-dark transition-colors text-sm"
        >
          Shop the Collection
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a
          href="/about"
          class="inline-flex items-center gap-2 border border-white/20 text-white font-semibold px-8 py-4 rounded-xl hover:bg-white/10 transition-colors text-sm"
        >
          Our Story
        </a>
      </div>
    </div>
  </section>

  <!-- Featured Products -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-end justify-between mb-12">
        <div>
          <p class="text-accent text-sm font-semibold uppercase tracking-widest mb-2">Featured</p>
          <h2 class="text-3xl sm:text-4xl font-black">Blessed & Bold</h2>
        </div>
        <a
          href="/products"
          class="hidden sm:inline-flex text-sm font-semibold text-gray-500 hover:text-accent transition-colors items-center gap-1"
        >
          View all
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {
          featured.map((product) => (
            <ProductCard
              id={product.id}
              name={product.data.name}
              description={product.data.description}
              price={product.data.price}
              image={product.data.images[0]}
              sizes={product.data.sizes}
              category={product.data.category}
              inStock={product.data.inStock}
            />
          ))
        }
      </div>

      <div class="mt-10 text-center sm:hidden">
        <a href="/products" class="text-sm font-semibold text-accent hover:underline">
          View all products →
        </a>
      </div>
    </div>
  </section>

  <!-- Brand Statement -->
  <section class="py-24 bg-surface">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <p class="text-accent text-sm font-semibold uppercase tracking-widest mb-4">Our Mission</p>
      <blockquote class="text-3xl sm:text-4xl font-black leading-snug text-primary">
        "Wear the saints. Live the sacraments.<br />
        <span class="text-accent">Carry the cross with joy."</span>
      </blockquote>
      <p class="mt-6 text-gray-500 text-lg leading-relaxed max-w-2xl mx-auto">
        FaithFuel was built for Catholics who want their everyday style to reflect their vocation.
        Each piece is a quiet act of evangelization — rooted in the Gospel, inspired by the saints.
      </p>
      <a
        href="/about"
        class="mt-8 inline-block border border-primary text-primary font-bold px-8 py-3.5 rounded-xl hover:bg-primary hover:text-white transition-colors text-sm"
      >
        Read Our Story
      </a>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="bg-accent py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl sm:text-4xl font-black text-white mb-4">
        Dress like a saint. Live like one too.
      </h2>
      <p class="text-white/80 mb-8 max-w-md mx-auto">
        Browse our full collection of Catholic-inspired tees. Free shipping on orders over $60.
      </p>
      <a
        href="/products"
        class="inline-block bg-white text-primary font-bold px-8 py-4 rounded-xl hover:bg-primary hover:text-white transition-colors text-sm"
      >
        Shop All Tees
      </a>
    </div>
  </section>
</MainLayout>
