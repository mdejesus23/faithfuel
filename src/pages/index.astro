---
import MainLayout from '../layouts/MainLayout.astro';
import ProductCard from '../components/ProductCard.astro';
import { getCollection } from 'astro:content';
import { ChevronRight, MoveRight } from '@lucide/astro';

const allProducts = await getCollection('products');
const featured = allProducts.filter((p) => p.data.featured).slice(0, 3);
---

<MainLayout
  title="Wear Your Faith"
  description="Catholic apparel rooted in tradition — t-shirts inspired by the saints, the Gospel, and the beauty of the faith."
>
  <!-- Hero -->
  <section
    class="bg-primary relative flex min-h-[90vh] items-center overflow-hidden"
  >
    <!-- Decorative background text -->
    <span
      class="pointer-events-none absolute inset-0 flex items-center justify-center text-[20vw] leading-none font-black text-white/3 select-none"
      aria-hidden="true"
    >
      FAITH
    </span>

    <div
      class="relative mx-auto max-w-7xl px-4 py-24 text-white sm:px-6 lg:px-8"
    >
      <p
        class="text-accent mb-4 text-sm font-semibold tracking-widest uppercase"
      >
        Rooted in Tradition — 2026
      </p>
      <h1
        class="max-w-2xl text-5xl leading-[1.05] font-black sm:text-6xl lg:text-7xl"
      >
        Clothed in<br /><span class="text-accent">His Grace.</span>
      </h1>
      <p class="mt-6 max-w-xl text-lg leading-relaxed text-gray-400">
        Faith-inspired apparel for Catholics who carry the cross daily — bold
        enough to witness, humble enough to serve.
      </p>
      <div class="mt-10 flex flex-wrap gap-4">
        <a
          href="/products"
          class="bg-accent hover:bg-accent-dark inline-flex items-center gap-2 rounded-xl px-8 py-4 text-sm font-bold text-white transition-colors"
        >
          Shop the Collection
          <MoveRight class="h-4 w-4" />
        </a>
        <a
          href="/about"
          class="inline-flex items-center gap-2 rounded-xl border border-white/20 px-8 py-4 text-sm font-semibold text-white transition-colors hover:bg-white/10"
        >
          Our Story
        </a>
      </div>
    </div>
  </section>

  <!-- Featured Products -->
  <section class="bg-white py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 flex items-end justify-between">
        <div>
          <p
            class="text-accent mb-2 text-sm font-semibold tracking-widest uppercase"
          >
            Featured
          </p>
          <h2 class="text-3xl font-black sm:text-4xl">Blessed & Bold</h2>
        </div>
        <a
          href="/products"
          class="hover:text-accent hidden items-center gap-1 text-sm font-semibold text-gray-500 transition-colors sm:inline-flex"
        >
          View all
          <ChevronRight class="h-4 w-4" />
        </a>
      </div>

      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          featured.map((product) => (
            <ProductCard
              id={product.id}
              name={product.data.name}
              description={product.data.description}
              price={product.data.price}
              image={product.data.images[0]}
              sizes={product.data.sizes}
              category={product.data.category}
              inStock={product.data.inStock}
            />
          ))
        }
      </div>

      <div class="mt-10 text-center sm:hidden">
        <a
          href="/products"
          class="text-accent text-sm font-semibold hover:underline"
        >
          View all products →
        </a>
      </div>
    </div>
  </section>

  <!-- Brand Statement -->
  <section class="bg-surface py-24">
    <div class="mx-auto max-w-4xl px-4 text-center sm:px-6">
      <p
        class="text-accent mb-4 text-sm font-semibold tracking-widest uppercase"
      >
        Our Mission
      </p>
      <blockquote
        class="text-primary text-3xl leading-snug font-black sm:text-4xl"
      >
        Seoul-Bound.<br />
        <span class="text-accent">Fueled by Faith.</span>
      </blockquote>
      <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-gray-500">
        <span class="text-primary font-semibold">100% of the funds</span> raised
        through every product sold go directly toward sending young Catholics to
        World Youth Day 2027 in Seoul, South Korea. Buy a shirt. Help send a
        pilgrim. See you in Seoul.
      </p>
      <a
        href="/about"
        class="border-primary text-primary hover:bg-primary mt-8 inline-block rounded-xl border px-8 py-3.5 text-sm font-bold transition-colors hover:text-white"
      >
        Read Our Story
      </a>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="bg-accent py-16">
    <div class="mx-auto max-w-7xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="mb-4 text-3xl font-black text-white sm:text-4xl">
        Every shirt sends a pilgrim to Seoul.
      </h2>
      <p class="mx-auto mb-8 max-w-md text-white/80">
        100% of proceeds go toward sending young Catholics to World Youth Day
        2027. Shop the collection and be part of the journey.
      </p>
      <a
        href="/products"
        class="text-primary hover:bg-primary inline-block rounded-xl bg-white px-8 py-4 text-sm font-bold transition-colors hover:text-white"
      >
        Shop All Tees
      </a>
    </div>
  </section>
</MainLayout>
