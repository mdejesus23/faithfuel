---
import { Image } from 'astro:assets';
import MainLayout from '../../layouts/MainLayout.astro';
import AddToCartButton from '../../components/cart/AddToCartButton';
import { getCollection } from 'astro:content';
import { ChevronDown } from '@lucide/astro';

export async function getStaticPaths() {
  const products = await getCollection('products');
  return products.map((product) => ({
    params: { slug: product.id },
    props: { product },
  }));
}

const { product } = Astro.props;
const {
  name,
  description,
  price,
  images,
  sizes,
  category,
  inStock,
  tags,
  seller,
} = product.data;

// Related: same category, exclude current
const allProducts = await getCollection('products');
const related = allProducts
  .filter((p) => p.data.category === category && p.id !== product.id)
  .slice(0, 3);
---

<MainLayout title={name} description={description}>
  <!-- Breadcrumb -->
  <div class="bg-surface border-b border-gray-100">
    <div class="mx-auto max-w-7xl px-4 py-3 sm:px-6 lg:px-8">
      <nav class="flex items-center gap-2 text-xs text-gray-400">
        <a href="/" class="hover:text-accent transition-colors">Home</a>
        <span>/</span>
        <a href="/products" class="hover:text-accent transition-colors"
          >Products</a
        >
        <span>/</span>
        <span class="text-primary font-medium">{name}</span>
      </nav>
    </div>
  </div>

  <!-- Product Detail -->
  <section class="bg-white py-14">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid items-start gap-12 md:grid-cols-2 lg:gap-20">
        <!-- Image Gallery -->
        <div class="flex flex-col gap-3">
          <!-- Main image display -->
          <div
            class="bg-surface relative aspect-square overflow-hidden rounded-2xl"
          >
            {
              images.map((img, i) => (
                <Image
                  src={img}
                  alt={`${name} – view ${i + 1}`}
                  class={`h-full w-full object-cover transition-opacity duration-300 ${i === 0 ? '' : 'pointer-events-none absolute inset-0 opacity-0'}`}
                  loading={i === 0 ? 'eager' : 'lazy'}
                  data-gallery-main={i}
                />
              ))
            }
          </div>

          <!-- Thumbnails (only shown if more than one image) -->
          {
            images.length > 1 && (
              <div class="flex gap-2">
                {images.map((img, i) => (
                  <button
                    type="button"
                    data-gallery-thumb={i}
                    aria-label={`View image ${i + 1}`}
                    class={`bg-surface aspect-square w-16 shrink-0 overflow-hidden rounded-lg border-2 transition-all focus:outline-none ${i === 0 ? 'border-accent' : 'border-transparent opacity-60 hover:opacity-100'}`}
                  >
                    <Image
                      src={img}
                      alt={`${name} thumbnail ${i + 1}`}
                      class="pointer-events-none h-full w-full object-cover"
                      loading="lazy"
                    />
                  </button>
                ))}
              </div>
            )
          }
        </div>

        <!-- Info -->
        <div class="flex flex-col gap-6">
          <div>
            <span
              class="bg-accent/10 text-accent mb-3 inline-block rounded-full px-3 py-1 text-xs font-semibold capitalize"
            >
              {category}
            </span>
            <h1 class="text-3xl leading-tight font-black sm:text-4xl">
              {name}
            </h1>
            <p class="mt-1 text-sm text-gray-400">by {seller}</p>
            <p class="text-primary mt-3 text-3xl font-black">
              ₱{price.toFixed(2)}
            </p>
          </div>

          <p class="leading-relaxed text-gray-600">{description}</p>

          {
            inStock ? (
              <AddToCartButton
                client:load
                id={product.id}
                name={name}
                price={price}
                image={images[0].src}
                sizes={sizes}
                seller={seller}
              />
            ) : (
              <div class="rounded-xl bg-gray-100 px-4 py-3 text-center text-sm font-semibold text-gray-500">
                Currently out of stock — check back soon.
              </div>
            )
          }

          <!-- Tags -->
          {
            tags && tags.length > 0 && (
              <div class="flex flex-wrap gap-2 border-t border-gray-100 pt-2">
                {tags.map((tag) => (
                  <span class="bg-surface rounded-full px-3 py-1 text-xs text-gray-400 capitalize">
                    #{tag}
                  </span>
                ))}
              </div>
            )
          }

          <!-- Details accordion (static) -->
          <details
            class="group overflow-hidden rounded-xl border border-gray-100"
          >
            <summary
              class="hover:bg-surface flex cursor-pointer list-none items-center justify-between px-5 py-4 text-sm font-semibold transition-colors select-none"
            >
              Care & Materials
              <ChevronDown />
            </summary>
            <div
              class="space-y-1 px-5 pb-4 text-sm leading-relaxed text-gray-500"
            >
              <p>• 100% ring-spun combed cotton</p>
              <p>• Machine wash cold, tumble dry low</p>
              <p>• Do not bleach. Do not iron on print.</p>
              <p>• Unisex sizing — runs true to size</p>
            </div>
          </details>
        </div>
      </div>
    </div>
  </section>

  <!-- Related Products -->
  {
    related.length > 0 && (
      <section class="bg-surface py-16">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
          <h2 class="mb-8 text-2xl font-black">You might also like</h2>
          <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {related.map((p) => (
              <a
                href={`/products/${p.id}`}
                class="group block overflow-hidden rounded-2xl border border-gray-100 bg-white transition-all hover:shadow-md"
              >
                <div class="bg-surface aspect-square overflow-hidden">
                  <Image
                    src={p.data.images[0]}
                    alt={p.data.name}
                    loading="lazy"
                    class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                  />
                </div>
                <div class="p-4">
                  <p class="text-sm font-bold">{p.data.name}</p>
                  <p class="text-accent mt-1 font-black">
                    ₱{p.data.price.toFixed(2)}
                  </p>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <script>
    const mains = document.querySelectorAll<HTMLElement>('[data-gallery-main]');
    const thumbs = document.querySelectorAll<HTMLButtonElement>(
      '[data-gallery-thumb]',
    );

    thumbs.forEach((thumb) => {
      thumb.addEventListener('click', () => {
        const idx = thumb.dataset.galleryThumb;

        mains.forEach((img) => {
          const active = img.dataset.galleryMain === idx;
          img.classList.toggle('opacity-0', !active);
          img.classList.toggle('pointer-events-none', !active);
          img.classList.toggle('absolute', !active);
          img.classList.toggle('inset-0', !active);
        });

        thumbs.forEach((t) => {
          const active = t.dataset.galleryThumb === idx;
          t.classList.toggle('border-accent', active);
          t.classList.toggle('border-transparent', !active);
          t.classList.toggle('opacity-60', !active);
        });
      });
    });
  </script>
</MainLayout>
