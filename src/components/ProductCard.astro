---
import AddToCartButton from './cart/AddToCartButton';

interface Props {
  id: string;
  name: string;
  description: string;
  price: number;
  image: string;
  sizes: string[];
  category: string;
  inStock: boolean;
}

const { id, name, description, price, image, sizes, category, inStock } = Astro.props;
---

<article class="group flex flex-col bg-white rounded-2xl overflow-hidden border border-gray-100 hover:shadow-lg transition-all duration-300">
  <!-- Image -->
  <a href={`/products/${id}`} class="block relative overflow-hidden bg-surface aspect-square">
    <img
      src={image}
      alt={name}
      loading="lazy"
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
    />
    {
      !inStock && (
        <div class="absolute inset-0 bg-white/70 flex items-center justify-center">
          <span class="bg-primary text-white text-xs font-semibold px-3 py-1 rounded-full">
            Out of Stock
          </span>
        </div>
      )
    }
    <span class="absolute top-3 left-3 bg-white text-gray-500 text-xs font-medium px-2.5 py-1 rounded-full capitalize">
      {category}
    </span>
  </a>

  <!-- Info -->
  <div class="flex flex-col flex-1 p-5">
    <a href={`/products/${id}`}>
      <h2 class="font-bold text-gray-900 leading-snug hover:text-accent transition-colors">
        {name}
      </h2>
    </a>
    <p class="mt-1.5 text-sm text-gray-500 line-clamp-2 leading-relaxed">{description}</p>

    <div class="mt-4 flex items-center justify-between">
      <span class="text-xl font-black text-primary">₱{price.toFixed(2)}</span>
    </div>

    <div class="mt-4">
      {
        inStock ? (
          <AddToCartButton
            client:load
            id={id}
            name={name}
            price={price}
            image={image}
            sizes={sizes}
          />
        ) : (
          <button
            disabled
            class="w-full py-2.5 rounded-xl bg-gray-100 text-gray-400 text-sm font-semibold cursor-not-allowed"
          >
            Out of Stock
          </button>
        )
      }
    </div>
  </div>
</article>
