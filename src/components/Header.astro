---
import CartIcon from './cart/CartIcon';

const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'Products', href: '/products' },
  { label: 'About', href: '/about' },
  { label: 'Contact', href: '/contact' },
];

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const isHomePage = currentPath === '/';
---

<header
  class="fixed inset-x-0 top-0 z-30 border-b border-gray-100 bg-white/95 backdrop-blur-sm"
>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between">
      <!-- Logo -->
      <a href="/" class="shrink-0 text-xl font-black tracking-tight">
        Faith<span class="text-accent">Fuel</span>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden items-center gap-8 md:flex">
        {
          navLinks.map((link) => (
            <a
              href={link.href}
              class={`hover:text-accent text-sm font-medium transition-colors ${
                currentPath === link.href ? 'text-accent' : 'text-gray-600'
              }`}
            >
              {link.label}
            </a>
          ))
        }
      </nav>

      <!-- Right: Cart + Hamburger -->
      <div class="flex items-center gap-2">
        <CartIcon client:load />

        <!-- Hamburger (mobile) -->
        <button
          id="menu-toggle"
          class="rounded-lg p-2 transition-colors hover:bg-gray-100 md:hidden"
          aria-label="Toggle menu"
          aria-expanded="false"
        >
          <svg
            id="icon-open"
            xmlns="http://www.w3.org/2000/svg"
            class="h-5 w-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
          <svg
            id="icon-close"
            xmlns="http://www.w3.org/2000/svg"
            class="hidden h-5 w-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Nav -->
  <div
    id="mobile-menu"
    class="hidden border-t border-gray-100 bg-white md:hidden"
  >
    <nav class="flex flex-col gap-1 px-4 py-4">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class={`hover:bg-surface hover:text-accent rounded-lg px-3 py-2.5 text-sm font-medium transition-colors ${
              currentPath === link.href
                ? 'text-accent bg-orange-50'
                : 'text-gray-700'
            }`}
          >
            {link.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
