---
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<div
  class:list={[
    'prose max-w-none',

    // Headings
    'prose-headings:font-sans prose-headings:font-bold prose-headings:tracking-tight',
    'prose-headings:text-neutral-800',

    // Paragraphs
    'prose-p:leading-relaxed prose-p:text-neutral-700',

    // Links
    'prose-a:text-primary prose-a:no-underline prose-a:underline-offset-4 hover:prose-a:underline hover:prose-a:text-accent-dark',

    // Strong / Emphasis
    'prose-strong:font-semibold prose-strong:text-primary',
    'prose-em:font-medium prose-em:text-accent-dark',

    // Inline code
    'prose-code:rounded-md prose-code:bg-surface prose-code:px-1.5 prose-code:py-0.5 prose-code:font-mono prose-code:text-primary prose-code:before:content-none prose-code:after:content-none',

    // Code blocks
    'prose-pre:rounded-xl prose-pre:border prose-pre:border-accent prose-pre:bg-surface',

    // Lists
    'prose-li:text-neutral-700 prose-li:marker:text-neutral-700',
    'prose-ol:pl-5 prose-ul:pl-5',

    // Images
    'prose-img:rounded-xl prose-img:border prose-img:border-accent',

    // Blockquotes
    'prose-blockquote:bg-surface prose-blockquote:rounded-r-lg prose-blockquote:border-l-4 prose-blockquote:border-l-primary prose-blockquote:py-1 prose-blockquote:pl-4 prose-blockquote:not-italic',

    // HR
    'prose-hr:border-accent',

    className,
  ]}
>
  <slot />
</div>
