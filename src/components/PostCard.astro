---
import { Image } from 'astro:assets';

interface Props {
  id: string;
  title: string;
  excerpt: string;
  author: string;
  date: Date;
  image: ImageMetadata;
  tags?: string[];
}

const { id, title, excerpt, author, date, image, tags } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article
  class="group flex flex-col overflow-hidden rounded-2xl border border-gray-100 bg-white transition-all duration-300 hover:shadow-lg"
>
  <a href={`/posts/${id}`} class="bg-surface relative block aspect-video overflow-hidden">
    <Image
      src={image}
      alt={title}
      loading="lazy"
      class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
    />
    {
      tags && tags.length > 0 && (
        <span class="absolute top-3 left-3 rounded-full bg-white px-2.5 py-1 text-xs font-medium text-gray-500 capitalize">
          {tags[0]}
        </span>
      )
    }
  </a>

  <div class="flex flex-1 flex-col p-5">
    <p class="text-xs text-gray-400">
      {author} · {formattedDate}
    </p>
    <a href={`/posts/${id}`}>
      <h3 class="hover:text-accent mt-1.5 font-bold leading-snug text-gray-900 transition-colors">
        {title}
      </h3>
    </a>
    <p class="mt-2 line-clamp-3 text-sm leading-relaxed text-gray-500">
      {excerpt}
    </p>
    <a
      href={`/posts/${id}`}
      class="text-accent mt-4 text-sm font-semibold hover:underline"
    >
      Read more →
    </a>
  </div>
</article>
